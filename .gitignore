# ---------------------------------------------------------------------------
# Secrets / env
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env
# keep examples
!.env.example
!**/.env.example

# Swarm stack files contain INTERNAL_AUTH_TOKEN in plain text.
# stack.resolved.yml is the source template; stack.deploy.yml is generated by deploy.sh.
stack.resolved.yml
stack.deploy.yml

# ---------------------------------------------------------------------------
# Node / Next.js (frontend)
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts.bak

# ---------------------------------------------------------------------------
# Python (backend)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# App data (SQLite, runtime)
# ---------------------------------------------------------------------------
backend/data/*.db
backend/data/*.db-journal
backend/data/*.db-wal
backend/data/*.db-shm

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# OS / editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
